# Sway config -- minimal bootable port from i3.
# Goal: confirm the Wayland session launches. Keybinds/session plumbing
# (keyring, polybar->waybar, xss-lock->swayidle, monitors) get ported after.
# Sway reads i3 syntax, so most of config/i3/config can be pasted in later.

set $mod Mod1
set $super Mod4
set $wallpaper $HOME/dotfiles/resources/linux-gruvbox.png
set $scripts $HOME/dotfiles/scripts

font pango:JetBrains Mono 10
smart_borders on
default_border pixel 1

# Gaps between tiled windows (inner) and screen edge (outer).
# smart_gaps on drops them when a workspace has a single window.
gaps inner 5
gaps outer 0
smart_gaps on

include /etc/sway/config.d/*

# --- Session target ------------------------------------------------------
# waybar (and other user units that want a graphical session) are pulled in by
# sway-session.target. Start it on launch, and tear it down when sway exits so
# those services do not linger. The subscribe call blocks until sway emits the
# "shutdown" event, then stops the target -- run it backgrounded via exec.
exec systemctl --user start sway-session.target
exec swaymsg -t subscribe '["shutdown"]' && systemctl --user stop sway-session.target

# --- Wallpaper -----------------------------------------------------------
output * bg $wallpaper fill

# --- Input ---------------------------------------------------------------
input type:keyboard {
    xkb_layout us
}

# Ducky Akko external board: swap Ctrl and CapsLock (ctrl:swapcaps).
input "3141:30264:Ducky_Akko_Keyboard" {
    xkb_layout us
    xkb_options ctrl:swapcaps
}

input "1452:627:Apple_Inc._Apple_Internal_Keyboard_/_Trackpad" {
    xkb_layout us
    xkb_options ctrl:swapcaps,altwin:swap_alt_win
}

exec_always xrdb -load "$HOME/.Xresources"
# Redirect each app's stdout/stderr to its own /tmp log so they don't bloat
# the sway log. exec runs through `sh -c`, so inline redirection works.
exec nm-applet >/tmp/nm-applet.log 2>&1
exec tailscale systray >/tmp/tailscale-systray.log 2>&1
exec flameshot >/tmp/flameshot.log 2>&1
exec slack --disable-features=WaylandFractionalScaleV1 >/tmp/slack.log 2>&1
exec discord >/tmp/discord.log 2>&1
exec Telegram >/tmp/telegram.log 2>&1
exec sourcegit >/tmp/sourcegit.log 2>&1

# --- Core keybinds (minimal) ---------------------------------------------
floating_modifier $mod
bindsym $mod+Return exec alacritty
bindsym $mod+Shift+q kill
bindsym $mod+space exec rofi -show drun
bindsym $mod+m exec kanshi-rofi.sh
bindsym $mod+Shift+c reload

# focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# move
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# split: new window opens beside (v) or below (b)
bindsym $mod+v split h
bindsym $mod+b split v

bindsym $mod+f fullscreen toggle

# change container layout (stacked, tabbed, toggle split)
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

# new windows that request focus get it (i3 parity)
focus_on_window_activation focus

# launchers / media (XF86 audio + brightness binds intentionally omitted)
bindsym $mod+p exec flameshot gui
bindsym $mod+n exec /bin/python /usr/bin/networkmanager_dmenu
# close all dunst notifications
bindsym Control+grave exec dunstctl close-all

# --- Scratchpad ----------------------------------------------------------
# mod+Shift+` stashes the focused window into the scratchpad; mod+` toggles the
# SourceGit scratchpad (its for_window rule below auto-stashes + sizes it).
bindsym $mod+Shift+grave move scratchpad
bindsym $mod+grave [class="SourceGit"] scratchpad show

# workspaces
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9
bindsym $mod+backslash workspace number 10
bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5
bindsym $mod+Shift+6 move container to workspace number 6
bindsym $mod+Shift+7 move container to workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9

# move the whole workspace to the other output
bindsym $mod+Control+j move workspace to output left
bindsym $mod+Control+k move workspace to output right

# --- Lock / idle ---------------------------------------------------------
# Replaces xss-lock + i3exit.sh. Plain swaylock + swayidle, both official
# repo (no AUR) and cross-compositor (work on hyprland too via ext-* protocols).
# -f forks after the lock is shown so swayidle's chain stays in order.
set $lock swaylock -f -i $wallpaper
exec swayidle -w \
    timeout 300 '$lock' \
    timeout 600 'swaymsg "output * power off"' resume 'swaymsg "output * power on"' \
    before-sleep '$lock'

# --- Resize mode ---------------------------------------------------------
# Port of i3's mode_resize (h/j/k/l, same 2px/2ppt steps).
set $mode_resize resize
mode "$mode_resize" {
    bindsym h resize shrink width 2 px or 2 ppt
    bindsym j resize grow height 2 px or 2 ppt
    bindsym k resize shrink height 2 px or 2 ppt
    bindsym l resize grow width 2 px or 2 ppt

    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "$mode_resize"

# --- Power mode ----------------------------------------------------------
# Port of i3's mode_power. i3exit.sh's actions map to sway/systemd natives:
# lock->$lock, exit->swaymsg exit, reboot/shutdown->systemctl. Each binding
# returns to default mode so the prompt dismisses after one action.
set $mode_power System (l)ock, (e)xit, (r)eboot, (s)hutdown
mode "$mode_power" {
    bindsym l exec $lock, mode "default"
    bindsym e exec swaymsg exit, mode "default"
    bindsym r exec systemctl reboot, mode "default"
    bindsym s exec systemctl poweroff, mode "default"

    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+0 mode "$mode_power"

# Status bar is waybar, started as a systemd user service (waybar.service,
# pulled in by sway-session.target). The built-in swaybar block is removed so
# the two do not stack.

# --- Window rules --------------------------------------------------------
# Ported from config/i3/config. Criteria use `class`, which matches XWayland
# windows; an app running native Wayland exposes `app_id` instead -- if a rule
# does not fire, check the window with `swaymsg -t get_tree` and swap criterion.

# pin apps to workspaces
for_window [app_id="1password"] move to workspace number 10
assign [app_id="slack"] number 3
assign [class="discord"] number 3
assign [app_id="org.telegram.desktop"] number 3

# SourceGit lives in the scratchpad: stash, size and centre it at launch
# (toggle with mod+`, see the Scratchpad section above).
for_window [class="SourceGit"] move scratchpad, \
    resize set 1360 850, \
    move absolute position center

# --- Colors --------------------------------------------------------------
# Gruvbox theme, ported verbatim from config/i3/config.
# class                 border  backgr  text    indicator child_border
client.focused          #a89984 #a89984 #32302f #6d8a68   #6d8a68
client.unfocused        #32302f #32302f #dfbf8e #32302f   #32302f
client.focused_inactive #32302f #32302f #dfbf8e #32302f   #32302f
