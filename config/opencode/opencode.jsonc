{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "theme": "gruvbox",
  "share": "disabled",
  "model": "litellm/anthropic.claude-sonnet-4-5-20250929-v1:0",
  "small_model": "litellm/gemini/gemini-flash-latest",
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Anduin Litellm",
      "options": {
        "baseURL": "https://litellm.anduin.center/v1",
        "apiKey": "{env:OPENAI_API_KEY}"
      },
      "models": {
        "anthropic.claude-sonnet-4-5-20250929-v1:0": {
          "name": "Anthropic Sonnet 4.5"
        },
        "anthropic.claude-opus-4-5-20251101-v1:0": {
          "name": "Anthropic Opus 4.5"
        },
        "gemini/gemini-flash-latest": {
          "name": "Gemini flash"
        }
      }
    }
  },
  "agent": {
    "plan": {
      "model": "litellm/anthropic.claude-opus-4-5-20251101-v1:0"
    }
  },
  "permission": {
    "bash": "deny",
    "webfetch": "ask",
    "websearch": "ask",
  },
  "mcp": {}
}
